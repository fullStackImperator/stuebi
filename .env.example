# PostgreSQL — Neon (empfohlen)
# Im Neon-Dashboard: Connection string kopieren.
# Für Next.js / Vercel meist die "Pooled connection" / "Transaction pooler" URL wählen
# (Host enthält oft "-pooler" oder "pooler") — weniger Verbindungen, besser für Serverless.
# Format siehe https://neon.tech/docs/connect/connect-from-any-app
#
# DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require

# PostgreSQL — lokal (optional, z. B. docker compose)
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/stuebi


# Payload (min 32 chars)
PAYLOAD_SECRET=change-me-to-a-long-random-string-32chars

# Public site URL (no trailing slash)
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Social — Facebook Page Plugin (public URL of the page)
NEXT_PUBLIC_FACEBOOK_PAGE_URL=https://www.facebook.com/your-page

# Social — optional Graph API (same Meta app; Page token with pages_read_engagement etc.)
FACEBOOK_PAGE_ACCESS_TOKEN=
FACEBOOK_PAGE_ID=
INSTAGRAM_BUSINESS_ACCOUNT_ID=

# Footer / CTAs
NEXT_PUBLIC_INSTAGRAM_URL=https://www.instagram.com/your-school
